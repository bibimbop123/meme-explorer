<div class="premium-page">
  <div class="premium-hero">
    <h1>🚀 Upgrade to Premium</h1>
    <p class="subtitle">Support the platform and unlock an ad-free experience</p>
  </div>

  <% if @is_premium %>
    <!-- Already Premium -->
    <div class="premium-active">
      <div class="success-badge">
        ✓ You're Premium!
      </div>
      <p>Thank you for supporting Meme Explorer! You're enjoying an ad-free experience.</p>
      
      <div class="subscription-management">
        <h3>Manage Subscription</h3>
        <button id="cancel-subscription-btn" class="btn-secondary">Cancel Subscription</button>
        <p class="note">You'll continue to have access until the end of your billing period.</p>
      </div>
    </div>
  <% else %>
    <!-- Pricing Plans -->
    <div class="pricing-cards">
      <div class="pricing-card">
        <div class="plan-header">
          <h2>Monthly</h2>
          <div class="price">
            <span class="amount">$2.99</span>
            <span class="period">/month</span>
          </div>
        </div>
        <ul class="features">
          <li>✓ Completely ad-free browsing</li>
          <li>✓ Support independent creators</li>
          <li>✓ Cancel anytime</li>
        </ul>
        <button class="checkout-btn" data-plan="monthly">
          Get Started
        </button>
      </div>

      <div class="pricing-card featured">
        <div class="best-value">BEST VALUE</div>
        <div class="plan-header">
          <h2>Yearly</h2>
          <div class="price">
            <span class="amount">$29.99</span>
            <span class="period">/year</span>
          </div>
          <div class="savings">Save $6/year</div>
        </div>
        <ul class="features">
          <li>✓ Completely ad-free browsing</li>
          <li>✓ Support independent creators</li>
          <li>✓ Cancel anytime</li>
          <li>✓ 2 months free!</li>
        </ul>
        <button class="checkout-btn" data-plan="yearly">
          Get Started
        </button>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="premium-faq">
      <h2>Frequently Asked Questions</h2>
      
      <div class="faq-item">
        <h3>How does it work?</h3>
        <p>Click "Get Started" on either plan to check out securely with Stripe. Once payment is complete, ads will be removed from your account immediately.</p>
      </div>

      <div class="faq-item">
        <h3>Can I cancel anytime?</h3>
        <p>Absolutely! You can cancel your subscription at any time from this page. You'll continue to enjoy premium benefits until the end of your billing period.</p>
      </div>

      <div class="faq-item">
        <h3>Is my payment secure?</h3>
        <p>Yes! We use Stripe, the industry standard for secure payment processing. We never see or store your credit card information.</p>
      </div>

      <div class="faq-item">
        <h3>Why support Meme Explorer?</h3>
        <p>Your support helps us maintain the platform, add new features, and keep bringing you the best memes without compromising user experience.</p>
      </div>
    </div>
  <% end %>
</div>

<style>
.premium-page {
  max-width: 1000px;
  margin: 0 auto;
  padding: 2rem 1rem;
}

.premium-hero {
  text-align: center;
  margin-bottom: 3rem;
}

.premium-hero h1 {
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
}

.premium-hero .subtitle {
  font-size: 1.2rem;
  color: #666;
}

.premium-active {
  text-align: center;
  padding: 2rem;
  background: #f0f9ff;
  border-radius: 12px;
  margin-bottom: 2rem;
}

.success-badge {
  display: inline-block;
  background: #10b981;
  color: white;
  padding: 0.5rem 1.5rem;
  border-radius: 50px;
  font-weight: bold;
  margin-bottom: 1rem;
}

.subscription-management {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid #ddd;
}

.pricing-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
  margin-bottom: 3rem;
}

.pricing-card {
  background: white;
  border: 2px solid #e5e7eb;
  border-radius: 12px;
  padding: 2rem;
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
}

.pricing-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.pricing-card.featured {
  border-color: #3b82f6;
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
}

.best-value {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: #3b82f6;
  color: white;
  padding: 0.25rem 1rem;
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: bold;
}

.plan-header {
  text-align: center;
  margin-bottom: 1.5rem;
}

.plan-header h2 {
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.price {
  margin: 1rem 0;
}

.price .amount {
  font-size: 2.5rem;
  font-weight: bold;
  color: #1f2937;
}

.price .period {
  font-size: 1rem;
  color: #6b7280;
}

.savings {
  color: #10b981;
  font-weight: bold;
  font-size: 0.9rem;
}

.features {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0;
}

.features li {
  padding: 0.75rem 0;
  border-bottom: 1px solid #f3f4f6;
}

.features li:last-child {
  border-bottom: none;
}

.checkout-btn {
  width: 100%;
  padding: 1rem;
  background: #3b82f6;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 1.1rem;
  font-weight: bold;
  cursor: pointer;
  transition: background 0.2s;
}

.checkout-btn:hover {
  background: #2563eb;
}

.btn-secondary {
  padding: 0.75rem 1.5rem;
  background: #ef4444;
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: bold;
}

.btn-secondary:hover {
  background: #dc2626;
}

.note {
  margin-top: 1rem;
  font-size: 0.875rem;
  color: #6b7280;
}

.premium-faq {
  margin-top: 4rem;
}

.premium-faq h2 {
  text-align: center;
  margin-bottom: 2rem;
}

.faq-item {
  margin-bottom: 2rem;
  padding: 1.5rem;
  background: #f9fafb;
  border-radius: 8px;
}

.faq-item h3 {
  margin-bottom: 0.5rem;
  color: #1f2937;
}

.faq-item p {
  color: #4b5563;
  line-height: 1.6;
}

@media (max-width: 768px) {
  .premium-hero h1 {
    font-size: 2rem;
  }
  
  .pricing-cards {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
// Handle checkout
document.querySelectorAll('.checkout-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    const plan = this.dataset.plan;
    this.disabled = true;
    this.textContent = 'Loading...';
    
    try {
      const response = await fetch('/premium/checkout', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `plan=${plan}`
      });
      
      const data = await response.json();
      
      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error('No checkout URL returned');
      }
    } catch (error) {
      alert('Error starting checkout. Please try again.');
      this.disabled = false;
      this.textContent = 'Get Started';
    }
  });
});

// Handle subscription cancellation
const cancelBtn = document.getElementById('cancel-subscription-btn');
if (cancelBtn) {
  cancelBtn.addEventListener('click', async function() {
    if (!confirm('Are you sure you want to cancel your subscription? You\'ll continue to have access until the end of your billing period.')) {
      return;
    }
    
    this.disabled = true;
    this.textContent = 'Canceling...';
    
    try {
      const response = await fetch('/premium/cancel', {
        method: 'POST'
      });
      
      const data = await response.json();
      
      if (data.success) {
        alert('Subscription canceled successfully.');
        location.reload();
      } else {
        throw new Error(data.error || 'Failed to cancel subscription');
      }
    } catch (error) {
      alert('Error canceling subscription: ' + error.message);
      this.disabled = false;
      this.textContent = 'Cancel Subscription';
    }
  });
}
</script>
