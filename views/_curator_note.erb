<% if curator_note %>
  <div class="curator-note">
    <div class="curator-header">
      <span class="curator-avatar"><%= curator_note[:curator][:avatar] %></span>
      <div class="curator-info">
        <div class="curator-name"><%= curator_note[:curator][:name] %></div>
        <div class="curator-label">Curator's Note</div>
      </div>
    </div>
    
    <div class="curator-commentary">
      "<%= curator_note[:note] %>"
    </div>
    
    <% if curator_note[:social_proof] %>
      <div class="social-proof">
        <span class="proof-icon">✨</span>
        <%= curator_note[:social_proof] %>
      </div>
    <% end %>
    
    <% if curator_note[:why_matters] %>
      <div class="why-matters">
        <div class="why-matters-label">Why This Matters</div>
        <div class="why-matters-text"><%= curator_note[:why_matters] %></div>
      </div>
    <% end %>
  </div>
<% end %>

<style>
  .curator-note {
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    border-left: 4px solid #667eea;
    padding: 1.5rem;
    margin: 1.5rem 0;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .curator-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .curator-avatar {
    font-size: 2.5rem;
    line-height: 1;
  }

  .curator-info {
    flex: 1;
  }

  .curator-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #2d3748;
  }

  .curator-label {
    font-size: 0.85rem;
    color: #718096;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 0.2rem;
  }

  .curator-commentary {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #2d3748;
    font-style: italic;
    margin-bottom: 1rem;
    padding-left: 1rem;
    border-left: 2px solid rgba(102, 126, 234, 0.3);
  }

  .social-proof {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #4a5568;
    background: rgba(255, 255, 255, 0.6);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  .proof-icon {
    font-size: 1.2rem;
  }

  .why-matters {
    background: rgba(102, 126, 234, 0.1);
    padding: 1rem;
    border-radius: 6px;
    border: 1px solid rgba(102, 126, 234, 0.2);
  }

  .why-matters-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: #667eea;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .why-matters-text {
    font-size: 0.95rem;
    color: #2d3748;
    line-height: 1.5;
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    .curator-note {
      background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
      border-left-color: #9f7aea;
    }

    .curator-name {
      color: #e2e8f0;
    }

    .curator-label {
      color: #a0aec0;
    }

    .curator-commentary {
      color: #e2e8f0;
      border-left-color: rgba(159, 122, 234, 0.3);
    }

    .social-proof {
      color: #cbd5e0;
      background: rgba(0, 0, 0, 0.3);
    }

    .why-matters {
      background: rgba(159, 122, 234, 0.15);
      border-color: rgba(159, 122, 234, 0.3);
    }

    .why-matters-label {
      color: #9f7aea;
    }

    .why-matters-text {
      color: #e2e8f0;
    }
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .curator-note {
      padding: 1rem;
      margin: 1rem 0;
    }

    .curator-avatar {
      font-size: 2rem;
    }

    .curator-commentary {
      font-size: 1rem;
      padding-left: 0.75rem;
    }

    .social-proof {
      font-size: 0.85rem;
      padding: 0.6rem 0.8rem;
    }

    .why-matters {
      padding: 0.8rem;
    }
  }
</style>
