<!-- Meme Controls Partial -->
<button class="control-btn" id="like-btn" title="Like this meme">
  ❤️
  <span class="control-count" id="like-count"><%= @likes %></span>
</button>

<button class="control-btn" id="save-btn" title="Save to profile">
  🔖
