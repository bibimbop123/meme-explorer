<div class="page-wrapper">
  <!-- Left Ad Column -->
  <% if should_show_ads? %>
    <aside class="ad-sidebar ad-sidebar-left">
      <%= render_ad_unit(0, format: 'vertical') %>
    </aside>
  <% end %>

  <!-- Center Content Column -->
  <div class="meme-container">
    <div class="meme-display" id="meme-display">
    <% if @meme && is_gallery_post?(@meme) && @meme["gallery_images"] %>
      <!-- Multi-image gallery carousel -->
      <%= gallery_styles %>
      <%= render_gallery_carousel(@meme["gallery_images"], @meme["title"]) %>
    <% else %>
      <!-- Single image/video display -->
      <button class="carousel-arrow carousel-arrow-left" id="carousel-prev" aria-label="Previous image" style="display: none;">‹</button>
      <div class="meme-display-content">
        <% if @meme %>
          <% media_type = @media_type || (File.extname(@image_src).downcase == '.mp4' || File.extname(@image_src).downcase == '.webm' ? 'video' : 'image') %>
          <% if media_type == 'video' %>
            <video src="<%= @image_src %>" controls autoplay muted loop style="max-width: 100%; max-height: 100%; object-fit: contain;">
              Your browser does not support the video tag.
            </video>
          <% else %>
            <img id="meme-image" src="<%= @image_src %>" alt="<%= @meme['title'] %>" onerror="showPlaceholder()" style="max-width: 100%; max-height: 100%; object-fit: contain; cursor: zoom-in;">
          <% end %>
        <% else %>
          <div class="meme-loading">
            <div class="loading-spinner"></div>
            <p class="loading-text"><%= PersonalityContent.random_loading_message %></p>
          </div>
        <% end %>
      </div>
      <button class="carousel-arrow carousel-arrow-right" id="carousel-next" aria-label="Next image" style="display: none;">›</button>
      <div class="carousel-counter" id="carousel-counter" style="display: none;">1/1</div>
    <% end %>
  </div>
  
  <!-- Caption centered below the meme -->
  <div class="meme-info" id="meme-info">
    <div class="meme-info-header">
      <div class="meme-title"><%= @meme&.dig('title') || 'Loading...' %></div>
      <button class="title-toggle-btn" id="title-toggle" aria-label="Toggle title visibility" title="Toggle title (T)">
        <span class="toggle-icon"></span>
      </button>
    </div>
    
    <!-- 🎬 CRITERION COLLECTION: Curated collection name instead of raw subreddit -->
    <% if @meme %>
      <% collection_name = collection_name_for_subreddit(@meme['subreddit']) %>
      <% rarity_data = calculate_rarity(@meme) %>
      
      <div class="refined-collection-badge">
        <%= collection_name %>
        <% if rarity_data[:label] != 'Common' %>
          <span class="rarity-indicator rarity-<%= rarity_data[:label].downcase %>">
            <%= rarity_data[:icon] %> <%= rarity_data[:label] %>
          </span>
        <% end %>
      </div>
      
      <!-- Curation signal - why this meme is being shown -->
      <% signal = generate_curation_signal(@meme) %>
      <div class="curation-signal curation-signal-<%= signal[:type] %>">
        <span class="signal-icon"><%= signal[:icon] %></span>
        <span class="signal-text"><%= signal[:message] %></span>
      </div>
    <% end %>
    
    <div class="meme-meta-wrapper">
      <div class="meme-meta">
      <% if @reddit_path || @meme&.dig('permalink') %>
        <a href="https://reddit.com<%= @reddit_path || @meme&.dig('permalink') %>" 
           target="_blank" rel="noopener" class="reddit-link refined-source-link" title="View original post on Reddit">
          Source →
        </a>
      <% end %>
      </div>
    </div>
  </div>

  <div class="meme-controls">
    <button class="control-btn" id="like-btn" title="Like this meme">
      ❤️
      <span class="control-count" id="like-count"><%= @likes %></span>
    </button>
    
    <button class="control-btn" id="save-btn" title="Save to profile">
      🔖
      <span class="control-count">Save</span>
    </button>
    
    <button class="control-btn" id="share-btn" title="Share">
      📤
      <span class="control-count">Share</span>
    </button>
    
    <!-- 🎬 QUICK WIN: More Like This button -->
    <% if @meme %>
      <button class="control-btn more-like-this-btn" id="more-like-this-btn" 
              data-subreddit="<%= @meme['subreddit'] %>"
              title="More from <%= collection_name_for_subreddit(@meme['subreddit']) %>">
        ✨
        <span class="control-count">More Like This</span>
      </button>
    <% end %>
    
    <button class="control-btn" id="next-btn" title="Next meme (Space or swipe)">
      ➡️
      <span class="control-count">Next</span>
    </button>
  </div>

  <div class="nav-hints-container">
    <div class="nav-hint"><%= PersonalityContent.random_nav_hint %></div>
    <div class="nav-hint"><%= PersonalityContent.time_greeting %></div>
    <% if session[:user_id] && @streak_data %>
      <div class="nav-hint" style="color: #ff6b6b; font-weight: bold;"><%= PersonalityContent.streak_encouragement(@streak_data[:days] || @streak_data[:current_streak] || 0) %></div>
    <% else %>
      <div class="nav-hint"><%= PersonalityContent.random_nav_hint %></div>
    <% end %>
  </div>

  <!-- PHASE 3: Near-Miss Tease -->
  <% if @tease %>
    <div class="near-miss-tease urgency-<%= @tease[:urgency] %>" id="near-miss-tease">
      <span class="tease-icon"><%= @tease[:icon] %></span>
      <span class="tease-message"><%= @tease[:message] %></span>
    </div>
  <% end %>

  <!-- GAMIFICATION: Milestone Celebration -->
  <% if @milestone %>
    <div class="milestone-celebration" id="milestone-celebration">
      <div class="milestone-content">
        <h2 class="milestone-title"><%= @milestone[:title] %></h2>
        <p class="milestone-message"><%= @milestone[:message] %></p>
        <button onclick="document.getElementById('milestone-celebration').style.display='none'" class="milestone-close">
          Continue
        </button>
      </div>
    </div>
  <% end %>

  <!-- GAMIFICATION: Surprise Reward -->
  <% if @surprise_reward %>
    <div class="surprise-reward" id="surprise-reward">
      <div class="reward-content">
        <div class="reward-icon"><%= @surprise_reward[:icon] %></div>
        <h3 class="reward-title"><%= @surprise_reward[:title] %></h3>
        <p class="reward-message"><%= @surprise_reward[:message] %></p>
        <button onclick="document.getElementById('surprise-reward').style.display='none'" class="reward-close">
          Awesome!
        </button>
      </div>
    </div>
  <% end %>

  <!-- GAMIFICATION: Progress Bar -->
  <% if @progress && @progress[:next_milestone] %>
    <div class="milestone-progress-bar" id="progress-bar">
      <div class="progress-text">
        <%= @progress[:memes_until_next] %> memes until next milestone! (Level <%= @progress[:current_count] %>)
      </div>
      <div class="progress-bar-container">
        <div class="progress-bar-fill" style="width: <%= @progress[:progress_percent] %>%"></div>
      </div>
    </div>
  <% end %>

  </div>

  <!-- Right Ad Column -->
  <% if should_show_ads? %>
    <aside class="ad-sidebar ad-sidebar-right">
      <%= render_ad_unit(1, format: 'vertical') %>
    </aside>
  <% end %>
</div>

<!-- Fullscreen Lightbox Modal -->
<div id="lightbox-modal" class="lightbox-modal" style="display: none;">
  <div class="lightbox-close" id="lightbox-close">✕</div>
  <div class="lightbox-content">
    <img id="lightbox-image" src="" alt="">
  </img>
</div>

<script>
  // ============================================
  // CONSOLE FILTER - Suppress external browser extension warnings
  // ============================================
  (function() {
    const originalWarn = console.warn;
    const originalLog = console.log;
    
    // List of patterns to filter out (browser extensions)
    const suppressPatterns = [
      /installHook\.js/i,
      /EternlDomAPI/i,
      /initEternlDomAPI/i,
      /overrideMethod/i,
      /chrome-extension:/i,
      /moz-extension:/i
    ];
    
    // Override console.warn to filter out extension warnings
    console.warn = function(...args) {
      const message = args.join(' ');
      const shouldSuppress = suppressPatterns.some(pattern => pattern.test(message));
      
      if (!shouldSuppress) {
        originalWarn.apply(console, args);
      }
    };
    
    // Override console.log to filter out extension logs
    console.log = function(...args) {
      const message = args.join(' ');
      const shouldSuppress = suppressPatterns.some(pattern => pattern.test(message));
      
      if (!shouldSuppress) {
        originalLog.apply(console, args);
      }
    };
    
    console.log('🧹 [CONSOLE] Extension warning filter active');
  })();
  
  // ============================================
  // REQUEST DEDUPLICATION & CACHING
  // ============================================
  const requestCache = new Map();
  const pendingRequests = new Map();
  
  async function cachedFetch(url, options = {}) {
    const cacheKey = `${url}:${JSON.stringify(options)}`;
    
    // Return cached result if available and fresh (< 5s)
    if (requestCache.has(cacheKey)) {
      const { data, timestamp } = requestCache.get(cacheKey);
      if (Date.now() - timestamp < 5000) {
        console.log(`✅ [CACHE HIT] ${url}`);
        return data;
      }
    }
    
    // Return pending request if already in flight (deduplicate)
    if (pendingRequests.has(cacheKey)) {
      console.log(`⏳ [DEDUP] Waiting for in-flight request: ${url}`);
      return pendingRequests.get(cacheKey);
    }
    
    // New request - add to pending
    const promise = fetch(url, options)
      .then(r => r.json())
      .then(data => {
        requestCache.set(cacheKey, { data, timestamp: Date.now() });
        pendingRequests.delete(cacheKey);
        return data;
      })
      .catch(err => {
        pendingRequests.delete(cacheKey);
        throw err;
      });
    
    pendingRequests.set(cacheKey, promise);
    return promise;
  }
  
  // Simple, elegant fallback - show CSS placeholder with skip button
  function showPlaceholder() {
    const img = document.getElementById('meme-image');
    const displayContent = document.querySelector('.meme-display-content');
    
    if (!img || !displayContent) return;
    
    // Hide broken image
    img.style.display = 'none';
    
    // Create placeholder
    const placeholder = document.createElement('div');
    placeholder.className = 'meme-placeholder';
    placeholder.innerHTML = `
      <div class="placeholder-shimmer"></div>
      <div class="placeholder-content">
        <div class="placeholder-icon">🎭</div>
        <h3>Content Unavailable</h3>
        <p>This meme couldn't be loaded from the source</p>
        <button onclick="loadNextMeme()" class="skip-btn">
          Skip to Next Meme →
        </button>
      </div>
    `;
    
    displayContent.appendChild(placeholder);
    
    console.log('ℹ️ Showing placeholder for failed image');
  }
  
  // Initialize current meme - no more preview images needed (backend handles validation)
  let currentMeme = {
    url: <%= @image_src.to_json %>,
    subreddit: <%= (@meme&.dig("subreddit") || "reddit").to_json %>,
    title: <%= (@meme&.dig("title") || "Unknown").to_json %>,
    media_type: <%= (detect_media_type(@image_src) rescue 'image').to_json %>
  };
  
  // BEHAVIORAL TRACKING: Track view start time for duration analytics
  let viewStartTime = Date.now();
  let memeViewData = { viewed: false, liked: false, saved: false, shared: false };
  
  const likeBtn = document.getElementById('like-btn');
  const likeCount = document.getElementById('like-count');
  const saveBtn = document.getElementById('save-btn');
  const nextBtn = document.getElementById('next-btn');
  const memeImg = document.querySelector('.meme-display img');
  const memeTitle = document.querySelector('.meme-title');
  const memeSub = document.querySelector('.meme-subreddit');
  const memeInfo = document.getElementById('meme-info');
  const titleToggle = document.getElementById('title-toggle');
  
  let isLiked = window.sessionLikedMemes ? window.sessionLikedMemes.includes(currentMeme.url) : false;
  
  // Title visibility state management - Desktop shows title by default, mobile allows toggle
  let isMobile = window.innerWidth <= 768;
  const savedVisibility = sessionStorage.getItem('titleVisible');
  // Desktop (>768px): title visible by default. Mobile (≤768px): title hidden by default
  let isTitleVisible = savedVisibility !== null ? savedVisibility === 'true' : !isMobile;
  
  // Initialize title visibility on page load
  function initializeTitleVisibility() {
    if (!isTitleVisible) {
      memeInfo.classList.add('title-hidden');
      memeInfo.classList.remove('title-visible');
    } else {
      memeInfo.classList.add('title-visible');
      memeInfo.classList.remove('title-hidden');
    }
  }
  
  initializeTitleVisibility();
  
  // Toggle title visibility AND progress bar
  function toggleTitleVisibility() {
    isTitleVisible = !isTitleVisible;
    sessionStorage.setItem('titleVisible', isTitleVisible);
    
    const progressBar = document.getElementById('progress-bar');
    
    if (isTitleVisible) {
      memeInfo.classList.remove('title-hidden');
      memeInfo.classList.add('title-visible');
      titleToggle.classList.remove('toggle-hidden');
      titleToggle.classList.add('toggle-visible');
      // Show progress bar
      if (progressBar) {
        progressBar.style.display = 'block';
        progressBar.style.opacity = '1';
      }
    } else {
      memeInfo.classList.remove('title-visible');
      memeInfo.classList.add('title-hidden');
      titleToggle.classList.remove('toggle-visible');
      titleToggle.classList.add('toggle-hidden');
      // Hide progress bar
      if (progressBar) {
        progressBar.style.display = 'none';
        progressBar.style.opacity = '0';
      }
    }
    
    // Haptic feedback - mobile devices
    if (navigator.vibrate) navigator.vibrate(20);
  }
  
  titleToggle.addEventListener('click', toggleTitleVisibility);
  
  // Keyboard shortcut: T key to toggle
  document.addEventListener('keydown', (e) => {
    if ((e.key === 't' || e.key === 'T') && document.activeElement.tagName !== 'INPUT') {
      toggleTitleVisibility();
    }
  });
  
  // Update like button UI - ENHANCED with clear liked/unliked states
  function updateLikeUI() {
    // Get the current count element (in case it was recreated)
    const currentCount = document.getElementById('like-count');
    
    if (isLiked) {
      // LIKED STATE: Bright red, glowing, scaled up, pulsing
      likeBtn.style.color = '#ff4458';
      likeBtn.style.filter = 'drop-shadow(0 0 15px #ff4458) brightness(1.3)';
      likeBtn.style.transform = 'scale(1.15)';
      likeBtn.classList.add('liked');
    } else {
      // UNLIKED STATE: White, no glow, normal size
      likeBtn.style.color = 'white';
      likeBtn.style.filter = 'none';
      likeBtn.style.transform = 'scale(1)';
      likeBtn.classList.remove('liked');
    }
    
    // Always show the counter - never hide it
    if (currentCount) {
      currentCount.style.display = 'inline';
    }
  }
  
  updateLikeUI();
  
  // AJAX: Load next meme without full page reload (deduplicated & cached) + behavioral tracking
  let loadingMeme = false;
  
  async function loadNextMeme() {
    // Prevent concurrent loads
    if (loadingMeme) {
      console.log('⏳ [LOAD MEME] Already loading, skipping duplicate request');
      return;
    }
    
    // BEHAVIORAL TRACKING: Track skip/view duration before loading next
    const viewDuration = (Date.now() - viewStartTime) / 1000;
    const action = viewDuration < 2 ? 'quick_skip' : 'skip';
    trackBehavioralAction(action, viewDuration);
    
    loadingMeme = true;
    
    try {
      console.log('🔄 [LOAD MEME] Starting fetch to /random.json...');
      const data = await cachedFetch('/random.json');
      
      console.log('✅ [LOAD MEME] JSON received:', data);
      
      // Validate response data
      if (!data || !data.url) {
        throw new Error(`Invalid meme data: ${JSON.stringify(data)}`);
      }
      
      // Update current meme object WITH gallery_images and media_type
      currentMeme = {
        url: data.url,
        subreddit: data.subreddit || 'REDDIT',
        title: data.title || 'Unknown',
        is_gallery: data.is_gallery || false,
        gallery_images: data.gallery_images || [],
        media_type: data.media_type || 'image'
      };
      
      // Reset fallback attempts for new meme
      fallbackAttempts.clear();
      
      // BEHAVIORAL TRACKING: Reset tracking for new meme
      viewStartTime = Date.now();
      memeViewData = { viewed: true, liked: false, saved: false, shared: false };
      
      // Update DOM - SINGLE SOURCE OF TRUTH for media updates
      updateMemeDisplay(data);
      
      // Update metadata
      memeTitle.textContent = data.title || 'Loading...';
      memeSub.textContent = (data.subreddit || 'REDDIT').toUpperCase();
      likeCount.textContent = data.likes;
      
      // Reset like state for new meme
      isLiked = false;
      updateLikeUI();
      
      // Update Reddit link if available
      const redditLink = document.querySelector('.reddit-link');
      if (redditLink && data.reddit_path) {
        redditLink.href = `https://reddit.com${data.reddit_path}`;
      }
      
      // Re-initialize carousel with new meme's images
      console.log('🎠 [LOAD MEME] Re-initializing carousel with new data...');
      initializeCarousel(data);
      
      // Multi-sensory feedback for next meme
      if (window.soundSystem) window.soundSystem.play('next');
      if (window.hapticSystem) window.hapticSystem.trigger('light');
      
      console.log('✅ [LOAD MEME] DOM updated successfully');
    } catch (e) {
      console.error('❌ [LOAD MEME] Error:', {
        message: e.message,
        stack: e.stack,
        type: e.constructor.name
      });
      console.warn('⚠️ [LOAD MEME] Falling back to full page reload...');
      // Fallback to full page reload on error
      setTimeout(() => {
        window.location.href = '/random';
      }, 100);
    } finally {
      loadingMeme = false;
    }
  }
  
  // SINGLE UPDATE FUNCTION - prevents duplicate DOM mutations
  function updateMemeDisplay(memeData) {
    // Safety check: ensure data and data.url exist
    if (!memeData || !memeData.url) {
      console.error('❌ [UPDATE DISPLAY] Invalid data:', memeData);
      return;
    }
    
    const mediaType = memeData.media_type || (memeData.url.endsWith('.mp4') || memeData.url.endsWith('.webm') ? 'video' : 'image');
    const memeDisplay = document.querySelector('.meme-display');
    
    if (!memeDisplay) {
      console.error('❌ [UPDATE DISPLAY] Meme display container not found');
      return;
    }
    
    if (mediaType === 'video') {
      const existingVid = memeDisplay.querySelector('video');
      if (existingVid) {
        existingVid.src = memeData.url;
        existingVid.play();
      } else {
        memeDisplay.innerHTML = `<video src="${memeData.url}" controls autoplay muted loop style="max-width: 100%; max-height: 100%; object-fit: contain;">Your browser does not support the video tag.</video>`;
      }
    } else {
      const video = memeDisplay.querySelector('video');
      if (video) {
        video.remove();
      }
      let img = memeDisplay.querySelector('img');
      if (!img) {
        img = document.createElement('img');
        img.id = 'meme-image';
        img.onerror = showPlaceholder;
        const displayContent = memeDisplay.querySelector('.meme-display-content');
        if (displayContent) {
          displayContent.appendChild(img);
        } else {
          memeDisplay.appendChild(img);
        }
      }
      img.src = memeData.url;
      img.alt = memeData.title || 'Meme';
    }
  }
  
  // Trigger heart pulse animation
  function triggerLikeAnimation() {
    likeBtn.classList.remove('heart-pulse');
    void likeBtn.offsetWidth;
    likeBtn.classList.add('heart-pulse');
  }

  // Like functionality (debounced - max 1 like per 500ms) with behavioral tracking
  let lastLikeTime = 0;
  likeBtn.addEventListener('click', async () => {
    const now = Date.now();
    if (now - lastLikeTime < 500) return; // Debounce
    lastLikeTime = now;
    
    try {
      triggerLikeAnimation();
      
      const response = await fetch('/like', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `url=${encodeURIComponent(currentMeme.url)}`
      });
      
      if (response.ok) {
        const data = await response.json();
        isLiked = data.liked;
        memeViewData.liked = isLiked;
        
        // BEHAVIORAL TRACKING: Track like action with duration
        trackBehavioralAction('like', (Date.now() - viewStartTime) / 1000);
        
        // Get fresh reference to counter element
        const currentCount = document.getElementById('like-count');
        const oldCount = parseInt(currentCount.textContent);
        const newCount = data.likes;
        
        if (oldCount !== newCount) {
          currentCount.classList.remove('count-bump');
          void currentCount.offsetWidth;
          currentCount.classList.add('count-bump');
        }
        
        currentCount.textContent = newCount;
        updateLikeUI();
        
        // Enhanced multi-sensory feedback!
        if (window.soundSystem) window.soundSystem.play('like');
        if (window.hapticSystem) window.hapticSystem.trigger(isLiked ? 'heartbeat' : 'light');
        
        // Particle celebration for likes!
        if (window.particleSystem && isLiked) {
          const rect = likeBtn.getBoundingClientRect();
          const x = rect.left + rect.width / 2;
          const y = rect.top + rect.height / 2;
          window.particleSystem.hearts(x, y, 8);
        }
        
        console.log(`❤️ [LIKE] Updated: liked=${isLiked}, count=${newCount}`);
      }
    } catch (e) {
      console.error('❌ [LIKE ERROR]', e);
    }
  });
  
  // Save functionality (debounced)
  let lastSaveTime = 0;
  saveBtn.addEventListener('click', async () => {
    const now = Date.now();
    if (now - lastSaveTime < 500) return; // Debounce
    lastSaveTime = now;
    
    if (!<%= session[:user_id] ? 'true' : 'false' %>) {
      window.location.href = '/login';
      return;
    }
    
    try {
      const response = await fetch('/api/save-meme', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `url=${encodeURIComponent(currentMeme.url)}&title=${encodeURIComponent(currentMeme.title)}&subreddit=${encodeURIComponent(currentMeme.subreddit)}`
      });
      
      if (response.ok) {
        saveBtn.style.color = '#ff4458';
        saveBtn.style.filter = 'drop-shadow(0 0 8px #ff4458)';
        
        // Enhanced multi-sensory feedback!
        if (window.soundSystem) window.soundSystem.play('save');
        if (window.hapticSystem) window.hapticSystem.trigger('success');
        
        // Star burst celebration for saves!
        if (window.particleSystem) {
          const rect = saveBtn.getBoundingClientRect();
          const x = rect.left + rect.width / 2;
          const y = rect.top + rect.height / 2;
          window.particleSystem.stars(x, y, 12);
        }
      }
    } catch (e) {
      console.error('Save error:', e);
    }
  });
  
  // Share functionality
  document.getElementById('share-btn').addEventListener('click', async () => {
    if (navigator.share) {
      try {
        await navigator.share({
          title: currentMeme.title,
          text: 'Check out this meme!',
          url: window.location.href
        });
      } catch (err) {
        console.log('Share cancelled');
      }
    } else {
      // Fallback: copy to clipboard
      navigator.clipboard.writeText(window.location.href).then(() => {
        alert('Link copied!');
      });
    }
  });
  
  // Keyboard & Swipe navigation - AJAX instead of full page reload (debounced)
  let touchStartX = 0;
  let touchEndX = 0;
  let lastNavTime = 0;
  
  function debounceNav() {
    const now = Date.now();
    if (now - lastNavTime < 300) return false; // Debounce nav to 300ms
    lastNavTime = now;
    return true;
  }
  
  // Handle window resize for responsive title visibility
  window.addEventListener('resize', () => {
    const newIsMobile = window.innerWidth <= 768;
    if (newIsMobile !== isMobile) {
      // Orientation or breakpoint changed
      isMobile = newIsMobile;
      
      // Auto-show title on desktop, hide on mobile (unless user overrode)
      if (!sessionStorage.getItem('titleVisible')) {
        isTitleVisible = !isMobile;
        initializeTitleVisibility();
      }
    }
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.code === 'Space' && document.activeElement.tagName !== 'INPUT') {
      e.preventDefault();
      if (debounceNav()) loadNextMeme();
    }
  });
  
  document.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });
  
  document.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    if (touchStartX - touchEndX > 50 && debounceNav()) {
      // Swiped left
      loadNextMeme();
    }
  });
  
  // ============================================
  // CAROUSEL FUNCTIONALITY
  // ============================================
  
  let carouselState = {
    images: [],
    currentIndex: 0,
    totalImages: 0
  };
  
  const carouselPrevBtn = document.getElementById('carousel-prev');
  const carouselNextBtn = document.getElementById('carousel-next');
  const carouselCounter = document.getElementById('carousel-counter');
  const memeDisplayContent = document.querySelector('.meme-display-content');
  
  // Initialize carousel from JSON data
  function initializeCarousel(data) {
    // Check if this is a gallery post with multiple images
    if (data.is_gallery && data.gallery_images && data.gallery_images.length > 0) {
      carouselState.images = data.gallery_images.map(img => img.url);
      carouselState.currentIndex = 0;
      carouselState.totalImages = data.gallery_images.length;
      
      console.log(`🎠 [CAROUSEL] Gallery post with ${carouselState.totalImages} images`);
    } else {
      // Single image - reset carousel
      carouselState.images = [data.url];
      carouselState.currentIndex = 0;
      carouselState.totalImages = 1;
      
      console.log(`🎠 [CAROUSEL] Single image post`);
    }
    
    // Show/hide carousel controls based on image count
    const showArrows = carouselState.totalImages > 1;
    carouselPrevBtn.style.display = showArrows ? 'block' : 'none';
    carouselNextBtn.style.display = showArrows ? 'block' : 'none';
    carouselCounter.style.display = showArrows ? 'block' : 'none';
    
    updateCarouselDisplay();
  }
  
  // Update carousel display
  function updateCarouselDisplay() {
    if (carouselState.totalImages <= 1) return;
    
    // Update counter
    carouselCounter.textContent = `${carouselState.currentIndex + 1}/${carouselState.totalImages}`;
    
    // Update arrow button states (disable at boundaries)
    carouselPrevBtn.disabled = carouselState.currentIndex === 0;
    carouselNextBtn.disabled = carouselState.currentIndex === carouselState.totalImages - 1;
    
    // Visual feedback for disabled buttons
    carouselPrevBtn.style.opacity = carouselPrevBtn.disabled ? '0.3' : '1';
    carouselNextBtn.style.opacity = carouselNextBtn.disabled ? '0.3' : '1';
  }
  
  // Navigate carousel
  function navigateCarousel(direction) {
    if (carouselState.totalImages <= 1) return;
    
    const newIndex = carouselState.currentIndex + direction;
    
    // Boundary check
    if (newIndex < 0 || newIndex >= carouselState.totalImages) return;
    
    carouselState.currentIndex = newIndex;
    
    // Update image
    const newImageUrl = carouselState.images[carouselState.currentIndex];
    if (newImageUrl) {
      const img = memeDisplayContent.querySelector('img');
      if (img) {
        img.src = newImageUrl;
        console.log(`🎠 [CAROUSEL] Navigated to image ${carouselState.currentIndex + 1}`);
      }
    }
    
    updateCarouselDisplay();
    
    // Haptic feedback
    if (navigator.vibrate) navigator.vibrate(20);
  }
  
  // Arrow button click handlers
  carouselPrevBtn.addEventListener('click', () => navigateCarousel(-1));
  carouselNextBtn.addEventListener('click', () => navigateCarousel(1));
  
  // Keyboard arrow navigation (separate from Space/next meme)
  document.addEventListener('keydown', (e) => {
    if (document.activeElement.tagName === 'INPUT') return;
    
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      navigateCarousel(-1);
    } else if (e.key === 'ArrowRight') {
      e.preventDefault();
      navigateCarousel(1);
    }
  });
  
  // Hook into loadNextMeme to reset carousel state
  const originalLoadNextMeme = loadNextMeme;
  loadNextMeme = async function() {
    const response = await originalLoadNextMeme.call(this);
    
    // After loading new meme, carousel will be re-initialized from JSON response
    return response;
  };
  
  // Next button click
  nextBtn.addEventListener('click', () => {
    if (debounceNav()) loadNextMeme();
  });
  
  // ============================================
  // IMPROVED: "MORE LIKE THIS" FUNCTIONALITY
  // Senior Engineer Implementation with proper error handling and UX
  // ============================================
  const moreLikeThisBtn = document.getElementById('more-like-this-btn');
  if (moreLikeThisBtn) {
    let lastClickTime = 0;
    const DEBOUNCE_MS = 500;
    
    moreLikeThisBtn.addEventListener('click', async () => {
      // Debounce to prevent rapid clicks
      const now = Date.now();
      if (now - lastClickTime < DEBOUNCE_MS) {
        console.log('⏳ [MORE LIKE THIS] Debounced - too soon');
        return;
      }
      lastClickTime = now;
      
      const subreddit = moreLikeThisBtn.dataset.subreddit;
      if (!subreddit) {
        console.error('❌ [MORE LIKE THIS] No subreddit data attribute');
        return;
      }
      
      console.log(`✨ [MORE LIKE THIS] Requesting similar content from r/${subreddit}`);
      
      // Store original state for restoration
      const countEl = moreLikeThisBtn.querySelector('.control-count');
      const originalText = countEl.textContent;
      const originalDisabled = moreLikeThisBtn.disabled;
      
      // Show loading state with visual feedback
      countEl.textContent = 'Finding...';
      moreLikeThisBtn.disabled = true;
      moreLikeThisBtn.style.opacity = '0.6';
      moreLikeThisBtn.style.cursor = 'wait';
      
      try {
        // Use dedicated similar endpoint with timeout
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 10000); // 10s timeout
        
        const response = await fetch(`/similar.json?subreddit=${encodeURIComponent(subreddit)}`, {
          signal: controller.signal
        });
        
        clearTimeout(timeoutId);
        
        // Handle HTTP errors
        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ error: 'Unknown error' }));
          throw new Error(errorData.error || `HTTP ${response.status}`);
        }
        
        const data = await response.json();
        
        // Validate response data
        if (!data || !data.url) {
          throw new Error('Invalid response data');
        }
        
        console.log(`✅ [MORE LIKE THIS] Found: "${data.title}" from r/${data.subreddit}`);
        
        // Track skip action before loading new meme
        const viewDuration = (Date.now() - viewStartTime) / 1000;
        trackBehavioralAction('more_like_this', viewDuration);
        
        // Update current meme state
        currentMeme = {
          url: data.url,
          subreddit: data.subreddit || subreddit,
          title: data.title || 'Unknown',
          is_gallery: data.is_gallery || false,
          gallery_images: data.gallery_images || [],
          media_type: data.media_type || 'image'
        };
        
        // Reset tracking for new meme
        viewStartTime = Date.now();
        memeViewData = { viewed: true, liked: false, saved: false, shared: false };
        
        // Update DOM elements
        updateMemeDisplay(data);
        memeTitle.textContent = data.title || 'Loading...';
        likeCount.textContent = data.likes || 0;
        
        // Update subreddit badge if exists
        const subredditBadge = document.querySelector('.refined-collection-badge');
        if (subredditBadge && data.subreddit) {
          // This will be updated on next page load, but we can update the button
          moreLikeThisBtn.dataset.subreddit = data.subreddit;
        }
        
        // Update Reddit link if available
        const redditLink = document.querySelector('.reddit-link');
        if (redditLink && data.reddit_path) {
          redditLink.href = `https://reddit.com${data.reddit_path}`;
        }
        
        // Reset like state
        isLiked = false;
        updateLikeUI();
        
        // Re-initialize carousel with new meme data
        initializeCarousel(data);
        
        // Reset prefetch state
        mediaLoadComplete = false;
        triggerPrefetchAfterMediaLoad();
        
        // Enhanced multi-sensory feedback for successful discovery
        if (window.soundSystem) window.soundSystem.play('next');
        if (window.hapticSystem) window.hapticSystem.trigger('success');
        
        // Show brief success indicator
        countEl.textContent = '✓ Found!';
        setTimeout(() => {
          countEl.textContent = originalText;
        }, 1500);
        
      } catch (error) {
        console.error('❌ [MORE LIKE THIS] Error:', error);
        
        // User-friendly error handling
        if (error.name === 'AbortError') {
          console.warn('⏱️ [MORE LIKE THIS] Request timed out');
          countEl.textContent = 'Timeout';
        } else if (error.message.includes('No similar memes')) {
          console.warn('ℹ️ [MORE LIKE THIS] No similar content found');
          countEl.textContent = 'None found';
        } else {
          countEl.textContent = 'Error';
        }
        
        // Fallback to regular next meme after brief delay
        setTimeout(() => {
          console.log('🔄 [MORE LIKE THIS] Falling back to random meme');
          loadNextMeme();
        }, 800);
        
      } finally {
        // Restore button state
        setTimeout(() => {
          moreLikeThisBtn.disabled = originalDisabled;
          moreLikeThisBtn.style.opacity = '';
          moreLikeThisBtn.style.cursor = '';
          if (countEl.textContent !== originalText && !countEl.textContent.includes('✓')) {
            countEl.textContent = originalText;
          }
        }, 1500);
      }
    });
  }
  
  // ============================================
  // PERFORMANCE: Prefetch next meme AFTER current media loads
  // ============================================
  let mediaLoadComplete = false;
  
  function triggerPrefetchAfterMediaLoad() {
    if (mediaLoadComplete) return; // Already triggered
    
    const img = memeDisplayContent.querySelector('img');
    const video = memeDisplayContent.querySelector('video');
    
    // Handler for when media finishes loading
    const onMediaReady = () => {
      if (mediaLoadComplete) return;
      mediaLoadComplete = true;
      
      console.log('✅ [MEDIA] Load complete - safe to prefetch');
      
      // Defer prefetch to next event loop (non-blocking)
      setTimeout(() => {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            console.log('📦 [PREFETCH] Loading next meme during idle time...');
            cachedFetch('/random.json').catch((err) => {
              console.log('ℹ️ [PREFETCH] Non-critical prefetch failed:', err.message);
            });
          }, { timeout: 2000 });
        } else {
          // Fallback for browsers without requestIdleCallback
          setTimeout(() => {
            console.log('📦 [PREFETCH] Loading next meme (no idle callback)...');
            cachedFetch('/random.json').catch((err) => {
              console.log('ℹ️ [PREFETCH] Non-critical prefetch failed:', err.message);
            });
          }, 1000);
        }
      }, 0);
    };
    
    // For images: use load event
    if (img) {
      img.addEventListener('load', onMediaReady, { once: true });
      // Fallback: if image is already cached/loaded
      if (img.complete) {
        onMediaReady();
      }
    }
    
    // For videos: use loadeddata event
    if (video) {
      video.addEventListener('loadeddata', onMediaReady, { once: true });
      // Fallback: if video is already cached/loaded
      if (video.readyState >= 2) {
        onMediaReady();
      }
    }
    
    // Safety timeout: prefetch anyway after 5 seconds
    setTimeout(() => {
      if (!mediaLoadComplete) {
        console.log('⏱️ [PREFETCH] Media load timeout - prefetching anyway');
        onMediaReady();
      }
    }, 5000);
  }
  
  // Start watching for media load completion
  triggerPrefetchAfterMediaLoad();
  
  // ============================================
  // BEHAVIORAL TRACKING SYSTEM
  // ============================================
  
  function trackBehavioralAction(action, duration) {
    // Track user behavior for personalization algorithm
    const trackingData = {
      meme_url: currentMeme.url,
      subreddit: currentMeme.subreddit,
      title: currentMeme.title,
      action: action,  // 'like', 'skip', 'quick_skip', 'save', 'share'
      duration: duration,
      timestamp: Date.now()
    };
    
    // Store in session storage for personalization
    try {
      const sessionBehavior = JSON.parse(sessionStorage.getItem('meme_behavior') || '[]');
      sessionBehavior.push(trackingData);
      
      // Keep last 50 interactions
      if (sessionBehavior.length > 50) {
        sessionBehavior.shift();
      }
      
      sessionStorage.setItem('meme_behavior', JSON.stringify(sessionBehavior));
      
      // Also send to backend for persistent learning (non-blocking)
      if (navigator.sendBeacon) {
        navigator.sendBeacon('/api/track-behavior', JSON.stringify(trackingData));
      }
      
      console.log(`📊 [BEHAVIOR] Tracked ${action} after ${duration.toFixed(1)}s`);
    } catch (e) {
      console.warn('[BEHAVIOR] Tracking error:', e);
    }
  }
  
  // Track page visibility for accurate duration
  document.addEventListener('visibilitychange', () => {
    if (document.hidden && memeViewData.viewed) {
      const duration = (Date.now() - viewStartTime) / 1000;
      trackBehavioralAction('view_end', duration);
    }
  });
  
  // Track session start
  if (!sessionStorage.getItem('session_start')) {
    sessionStorage.setItem('session_start', Date.now().toString());
    sessionStorage.setItem('memes_viewed_count', '1');
  } else {
    const count = parseInt(sessionStorage.getItem('memes_viewed_count') || '0') + 1;
    sessionStorage.setItem('memes_viewed_count', count.toString());
  }
  
  // ============================================
  // LIGHTBOX FUNCTIONALITY
  // ============================================
  
  const lightboxModal = document.getElementById('lightbox-modal');
  const lightboxImage = document.getElementById('lightbox-image');
  const lightboxClose = document.getElementById('lightbox-close');
  
  // Open lightbox when clicking meme image
  function openLightbox() {
    const memeImage = document.getElementById('meme-image');
    if (memeImage && memeImage.src) {
      lightboxImage.src = memeImage.src;
      lightboxImage.alt = memeImage.alt;
      lightboxModal.style.display = 'flex';
      document.body.style.overflow = 'hidden'; // Prevent scrolling
      console.log('🖼️ [LIGHTBOX] Opened');
    }
  }
  
  // Close lightbox
  function closeLightbox() {
    lightboxModal.style.display = 'none';
    document.body.style.overflow = ''; // Restore scrolling
    console.log('🖼️ [LIGHTBOX] Closed');
  }
  
  // Attach click handler to meme image
  function attachLightboxHandler() {
    const memeImage = document.getElementById('meme-image');
    if (memeImage) {
      memeImage.style.cursor = 'zoom-in';
      memeImage.addEventListener('click', openLightbox);
    }
  }
  
  // Initial attachment
  attachLightboxHandler();
  
  // Close button click
  lightboxClose.addEventListener('click', closeLightbox);
  
  // Click outside image to close
  lightboxModal.addEventListener('click', (e) => {
    if (e.target === lightboxModal) {
      closeLightbox();
    }
  });
  
  // ESC key to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightboxModal.style.display === 'flex') {
      closeLightbox();
    }
  });
  
  // Re-attach handler when meme changes
  const originalUpdateMemeDisplay = updateMemeDisplay;
  updateMemeDisplay = function(memeData) {
    originalUpdateMemeDisplay(memeData);
    setTimeout(() => attachLightboxHandler(), 100);
  };
</script>

