<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🏆 Leaderboard - Meme Explorer</title>
  <link rel="stylesheet" href="/css/meme_explorer.css">
  <link rel="stylesheet" href="/css/leaderboard.css">
</head>
<body>
  <div class="leaderboard-container">
    <!-- Header -->
    <header class="leaderboard-header">
      <h1 class="leaderboard-title">🏆 Leaderboard</h1>
    </header>

    <!-- Leaderboard Type Selector -->
    <nav class="leaderboard-type-selector" role="navigation" aria-label="Leaderboard types">
      <a href="?type=weekly" 
         class="leaderboard-type-btn <%= @leaderboard_type == :weekly ? 'active' : '' %>" 
         data-type="weekly">
        📅 Weekly Champions
      </a>
      <a href="?type=monthly"
         class="leaderboard-type-btn <%= @leaderboard_type == :monthly ? 'active' : '' %>"
         data-type="monthly">
        📆 Monthly Champions
      </a>
      <a href="?type=all_time" 
         class="leaderboard-type-btn <%= @leaderboard_type == :all_time ? 'active' : '' %>" 
         data-type="all_time">
        ⏰ All-Time Legends
      </a>
      <a href="?type=streak"
         class="leaderboard-type-btn <%= @leaderboard_type == :streak ? 'active' : '' %>"
         data-type="streak">
        🔥 Streak Champions
      </a>
    </nav>

    <!-- Period Selector (for weekly/monthly only) -->
    <% if @leaderboard_type == :weekly || @leaderboard_type == :monthly %>
      <div class="period-selector">
        <select id="period-select" aria-label="Select time period">
          <option value="">Current <%= @leaderboard_type == :weekly ? 'Week' : 'Month' %></option>
          <% if @previous_periods && @previous_periods.any? %>
            <% @previous_periods.each do |period| %>
              <option value="<%= period[:value] %>" <%= @current_period == period[:value] ? 'selected' : '' %>>
                <%= period[:label] %>
              </option>
            <% end %>
          <% end %>
        </select>
        <button id="refresh-btn" class="leaderboard-pagination__btn" aria-label="Refresh leaderboard">
          🔄 Refresh
        </button>
      </div>
    <% end %>

    <!-- Weekly Challenge Banner -->
    <% if @challenge %>
      <div class="challenge-banner" role="region" aria-label="Weekly challenge">
        <h2 class="challenge-banner__title">🎯 Weekly Challenge</h2>
        <p class="challenge-banner__description"><%= @challenge[:description] %></p>
        <p class="challenge-banner__reward">Reward: <%= @challenge[:reward_xp] %> XP</p>
        
        <% if @challenge_progress %>
          <div class="challenge-progress">
            <p style="margin: 0 0 0.5rem 0; font-size: 0.9rem;">
              Your Progress: <%= @challenge_progress[:current] %> / <%= @challenge_progress[:required] %>
            </p>
            <div class="challenge-progress__bar-container" role="progressbar" 
                 aria-valuenow="<%= (@challenge_progress[:current].to_f / @challenge_progress[:required] * 100).round %>"
                 aria-valuemin="0" 
                 aria-valuemax="100">
              <div class="challenge-progress__bar" 
                   style="width: <%= [(@challenge_progress[:current].to_f / @challenge_progress[:required] * 100).round, 100].min %>%">
                <%= [(@challenge_progress[:current].to_f / @challenge_progress[:required] * 100).round, 100].min %>%
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Your Rank Card -->
    <% if @user_rank %>
      <div class="user-rank-card" id="user-rank-card" role="region" aria-label="Your current rank">
        <h3 class="user-rank-card__title">Your Rank</h3>
        <div class="user-rank-card__rank">
          #<%= @user_rank['rank'] %>
          <% if @rank_change && @rank_change[:change] %>
            <% change = @rank_change[:change].abs %>
            <% direction = @rank_change[:direction] %>
            <% if direction == 'up' %>
              <span class="rank-change rank-change--up" aria-label="Moved up <%= change %> positions">
                ↑<%= change %>
              </span>
            <% elsif direction == 'down' %>
              <span class="rank-change rank-change--down" aria-label="Moved down <%= change %> positions">
                ↓<%= change %>
              </span>
            <% elsif direction == 'same' %>
              <span class="rank-change rank-change--same" aria-label="Rank unchanged">−</span>
            <% end %>
          <% end %>
        </div>
        <div class="user-rank-card__stats">
          <span class="user-rank-card__stat">⭐ Level <%= @user_rank['level'] || 1 %></span>
          <span class="user-rank-card__stat">🔥 <%= @user_rank['total_xp'] || @user_rank['score'] || 0 %> XP</span>
          <span class="user-rank-card__stat">💪 <%= @user_rank['score'] || 0 %> points this <%= @leaderboard_type == :weekly ? 'week' : 'month' %></span>
        </div>
        <button class="share-rank-btn leaderboard-pagination__btn" 
                style="margin-top: 1rem; background: rgba(255,255,255,0.2); border: none; color: white;"
                aria-label="Share your rank">
          📤 Share Your Rank
        </button>
      </div>
    <% end %>

    <!-- Insights Section -->
    <% if @insights && @insights.any? %>
      <div class="leaderboard-insights" id="leaderboard-insights" role="region" aria-label="Performance insights">
        <h3 class="leaderboard-insights__title">
          💡 Insights
        </h3>
        <ul class="leaderboard-insights__list">
          <% @insights.each do |insight| %>
            <li class="leaderboard-insights__item">
              <span class="leaderboard-insights__icon"><%= insight[:icon] %></span>
              <span><%= insight[:text] %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Top Leaderboard -->
    <section class="leaderboard-section" role="region" aria-label="Top rankings">
      <h2 class="leaderboard-section__title">
        <%= 
          case @leaderboard_type
          when :weekly then '📅 Weekly Champions'
          when :monthly then '📆 Monthly Champions'
          when :all_time then '⏰ All-Time Legends'
          when :streak then '🔥 Streak Champions'
          else 'Top Meme Connoisseurs'
          end
        %>
      </h2>
      
      <!-- Loading Indicator -->
      <div id="loading-indicator" class="leaderboard-loading" style="display: none;">
        <div class="leaderboard-loading__spinner" aria-label="Loading"></div>
        <p>Loading leaderboard...</p>
      </div>

      <!-- Leaderboard List -->
      <div class="leaderboard-list" id="leaderboard-list">
        <% if @leaderboard && @leaderboard.any? %>
          <% @leaderboard.each_with_index do |entry, index| %>
            <%
              rank = entry['rank'] || (index + 1)
              is_current_user = session[:user_id] && entry['user_id'].to_i == session[:user_id].to_i
              entry_classes = ['leaderboard-entry']
              
              if rank <= 3
                entry_classes << 'leaderboard-entry--podium'
                entry_classes << "leaderboard-entry--top#{rank}"
              end
              entry_classes << 'leaderboard-entry--current-user' if is_current_user
            %>
            <div class="<%= entry_classes.join(' ') %>" 
                 data-user-id="<%= entry['user_id'] %>" 
                 data-rank="<%= rank %>"
                 tabindex="0"
                 role="listitem">
              
              <!-- Rank -->
              <% if rank == 1 %>
                <span class="leaderboard-entry__rank leaderboard-entry__rank--medal" aria-label="First place">🥇</span>
              <% elsif rank == 2 %>
                <span class="leaderboard-entry__rank leaderboard-entry__rank--medal" aria-label="Second place">🥈</span>
              <% elsif rank == 3 %>
                <span class="leaderboard-entry__rank leaderboard-entry__rank--medal" aria-label="Third place">🥉</span>
              <% else %>
                <div class="leaderboard-entry__rank" aria-label="Rank <%= rank %>">#<%= rank %></div>
              <% end %>
              
              <!-- User Info -->
              <div class="leaderboard-entry__info">
                <div class="leaderboard-entry__username">
                  <%= entry['reddit_username'] || entry['email']&.split('@')&.first || "User ##{entry['user_id']}" %>
                  <% if is_current_user %>
                    <span style="color: var(--leaderboard-accent); margin-left: 0.5rem;">👋 You</span>
                  <% end %>
                </div>
                <div class="leaderboard-entry__stats">
                  <span class="leaderboard-entry__stat">⭐ Level <%= entry['level'] || 1 %></span>
                  <span class="leaderboard-entry__stat">🔥 <%= entry['total_xp'] || entry['score'] || 0 %> XP</span>
                  <% if entry['current_streak'] && entry['current_streak'].to_i > 0 %>
                    <span class="leaderboard-entry__stat">📅 <%= entry['current_streak'] %> day streak</span>
                  <% end %>
                  <% if entry['longest_streak'] && @leaderboard_type == :streak %>
                    <span class="leaderboard-entry__stat">🏅 Best: <%= entry['longest_streak'] %> days</span>
                  <% end %>
                </div>
              </div>
              
              <!-- Score -->
              <div class="leaderboard-entry__score-container">
                <div class="leaderboard-entry__score"><%= entry['score'] || 0 %></div>
                <div class="leaderboard-entry__score-label">
                  <%= @leaderboard_type == :streak ? 'days' : 'points' %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="leaderboard-empty">
            <div class="leaderboard-empty__icon">🏆</div>
            <h3 class="leaderboard-empty__title">No Rankings Yet</h3>
            <p class="leaderboard-empty__message">Be the first to climb the leaderboard!</p>
          </div>
        <% end %>
      </div>

      <!-- Load More Button -->
      <div class="leaderboard-pagination">
        <button id="load-more-btn" class="leaderboard-pagination__btn" style="display: none;">
          Load More
        </button>
      </div>
    </section>

    <!-- Nearby Competitors (for logged-in users) -->
    <% if @nearby && @nearby.any? %>
      <section class="leaderboard-section nearby-competitors" id="nearby-competitors">
        <h2 class="nearby-competitors__title">🎯 Your Nearby Competitors</h2>
        <div class="leaderboard-list">
          <% @nearby.each_with_index do |entry, index| %>
            <%
              rank = entry['rank']
              is_current_user = session[:user_id] && entry['user_id'].to_i == session[:user_id].to_i
              entry_classes = ['leaderboard-entry']
              entry_classes << 'leaderboard-entry--current-user' if is_current_user
            %>
            <div class="<%= entry_classes.join(' ') %>" 
                 data-user-id="<%= entry['user_id'] %>" 
                 data-rank="<%= rank %>">
              <div class="leaderboard-entry__rank">#<%= rank %></div>
              <div class="leaderboard-entry__info">
                <div class="leaderboard-entry__username">
                  <%= entry['reddit_username'] || entry['email']&.split('@')&.first || "User ##{entry['user_id']}" %>
                  <% if is_current_user %>
                    <span style="color: var(--leaderboard-accent);">👋 You</span>
                  <% end %>
                </div>
                <div class="leaderboard-entry__stats">
                  <span class="leaderboard-entry__stat">⭐ Level <%= entry['level'] || 1 %></span>
                  <span class="leaderboard-entry__stat">🔥 <%= entry['total_xp'] || 0 %> XP</span>
                </div>
              </div>
              <div class="leaderboard-entry__score-container">
                <div class="leaderboard-entry__score"><%= entry['score'] || 0 %></div>
                <div class="leaderboard-entry__score-label">points</div>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <!-- How It Works -->
    <section class="how-it-works">
      <h3 class="how-it-works__title">📚 How It Works</h3>
      <ul class="how-it-works__list">
        <li><strong>Like memes</strong> - Earn 10 XP per like and climb the weekly leaderboard</li>
        <li><strong>Save memes</strong> - Earn 15 XP per save for your favorite content</li>
        <li><strong>Daily streaks</strong> - Visit daily to build your streak and earn bonus XP</li>
        <li><strong>Weekly challenges</strong> - Complete special tasks for bonus rewards</li>
        <li><strong>Level up</strong> - Gain XP to increase your level and unlock titles</li>
        <li><strong>Compete</strong> - Multiple leaderboards: Weekly, Monthly, All-Time, and Streaks!</li>
        <li><strong>Rewards</strong> - Top 10 weekly performers earn bonus XP and badges</li>
      </ul>
    </section>

    <!-- Back Button -->
    <div style="text-align: center; margin-top: 2rem;">
      <a href="/" class="leaderboard-pagination__btn">← Back to Memes</a>
    </div>
  </div>

  <!-- JavaScript -->
  <script src="/js/leaderboard.js"></script>
  
  <script>
    // Pass server data to JavaScript - Always start with current session state
    window.LEADERBOARD_DATA = {
      type: '<%= @leaderboard_type || 'weekly' %>',
      period: '<%= @current_period || '' %>',
      userId: <%= session[:user_id] ? session[:user_id] : 'null' %>,
      isLoggedIn: <%= session[:user_id] ? 'true' : 'false' %>
    };
    
    // Log initial state for debugging
    console.log('🔐 Leaderboard Initial State:', {
      isLoggedIn: window.LEADERBOARD_DATA.isLoggedIn,
      userId: window.LEADERBOARD_DATA.userId,
      hasSession: <%= session[:user_id] ? 'true' : 'false' %>
    });
  </script>
</body>
</html>
