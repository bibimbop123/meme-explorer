<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @page_title %></title>
  <meta name="description" content="<%= @page_description %>">
  <meta name="robots" content="index, follow">
  
  <!-- Open Graph -->
  <meta property="og:title" content="<%= @page_title %>">
  <meta property="og:description" content="<%= @page_description %>">
  
  <link rel="stylesheet" href="/css/meme_explorer.css">
  
  <style>
    .formats-header {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }
    .formats-header h1 {
      margin: 0 0 10px 0;
      font-size: 3em;
    }
    .formats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      padding: 40px 20px;
      max-width: 1400px;
      margin: 0 auto;
    }
    .format-card {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      transition: all 0.3s;
      text-align: center;
    }
    .format-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }
    .format-card h2 {
      margin: 0 0 15px 0;
      font-size: 24px;
      color: #3b82f6;
    }
    .format-card a {
      text-decoration: none;
      color: inherit;
    }
    .format-stats {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 15px;
      font-size: 14px;
      color: #666;
    }
    .format-icon {
      font-size: 48px;
      margin-bottom: 15px;
    }
    .explore-btn {
      display: inline-block;
      margin-top: 15px;
      padding: 10px 25px;
      background: #3b82f6;
      color: white;
      border-radius: 25px;
      text-decoration: none;
      transition: background 0.3s;
    }
    .explore-btn:hover {
      background: #2563eb;
    }
  </style>
</head>
<body>
  <div class="formats-header">
    <h1>🎨 Meme Formats Directory</h1>
    <p>Explore <%= @formats.size %> popular meme categories</p>
  </div>
  
  <div class="formats-grid">
    <% @formats.each do |format| %>
      <div class="format-card">
        <div class="format-icon">
          <%= ['🔥', '😂', '💯', '⚡', '🎯', '🌟', '💎', '🚀'].sample %>
        </div>
        <h2>
          <a href="/memes/category/<%= format[:slug] %>">
            <%= format[:name] %>
          </a>
        </h2>
        <div class="format-stats">
          <span>📊 <%= format[:count] %> memes</span>
          <span>👍 <%= format[:likes] %> likes</span>
        </div>
        <a href="/memes/category/<%= format[:slug] %>" class="explore-btn">
          Explore →
        </a>
      </div>
    <% end %>
  </div>
  
  <footer style="text-align: center; padding: 60px 20px; background: #f5f5f5;">
    <p><a href="/">Home</a> | <a href="/random">Random</a> | <a href="/trending">Trending</a> | <a href="/sitemap">Sitemap</a></p>
    <p>&copy; 2026 Meme Explorer - Your destination for the funniest memes</p>
  </footer>
</body>
</html>
