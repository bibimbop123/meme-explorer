# Meme Explorer Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Core Application
# ============================================
RACK_ENV=production
PORT=8080
SESSION_SECRET=your-random-secret-key-here

# ============================================
# Database (SQLite - current)
# ============================================
DATABASE_TYPE=sqlite3
DATABASE_PATH=db/memes.db

# ============================================
# PostgreSQL (Uncomment after migration)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/meme_explorer_dev
# DB_TYPE=postgres

# ============================================
# Redis (Session & Cache)
# ============================================
REDIS_URL=rediss://username:password@your-redis-host:6379

# ============================================
# Advertisement Configuration (Google AdSense)
# ============================================
# Get your AdSense Client ID from https://www.google.com/adsense
# Site Verification Code (get from Google Search Console)
GOOGLE_SITE_VERIFICATION=your-verification-code-here
# GOOGLE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# GOOGLE_AD_SLOT_SQUARE=XXXXXXXXXX
# GOOGLE_AD_SLOT_BANNER=XXXXXXXXXX
# GOOGLE_AD_SLOT_NATIVE=XXXXXXXXXX

# Ad Frequency (show ad every N memes)
# Recommended: 12 for good UX, 8-10 for more revenue
AD_FREQUENCY=12

# Disable all ads (for testing or premium users)
# DISABLE_ADS=false

# ============================================
# Reddit OAuth2 (Get from https://www.reddit.com/prefs/apps)
# ============================================
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_REDIRECT_URI=http://localhost:3000/auth/reddit/callback
# Reddit API User-Agent — must be a real Reddit username per Reddit ToS
REDDIT_USERNAME=your_reddit_bot_account_username

# For production:
# REDDIT_REDIRECT_URI=https://meme-explorer.onrender.com/auth/reddit/callback

# ============================================
# Sentry Error Tracking
# Get SENTRY_DSN from https://sentry.io/account/
# ============================================
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# For development:
# SENTRY_DSN=https://your-key@sentry.io/your-project-id
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.0

# ============================================
# Puma Web Server
# ============================================
WEB_CONCURRENCY=1
RAILS_MAX_THREADS=5

# ============================================
# Feature Flags
# ============================================
PHASE_3_ENABLED=true
ENABLE_SPACED_REPETITION=true
ENABLE_PERSONALIZATION=true
